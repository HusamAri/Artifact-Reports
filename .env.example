# =============================================================================
# Artifact-Reports — environment variables
# Copy to .env (root), app/.env, web-report/.env, supabase/.env as needed.
# DO NOT COMMIT real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (shared)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server / edge functions only — never ship in app

# -----------------------------------------------------------------------------
# Apple StoreKit / App Store Server API
# -----------------------------------------------------------------------------
APPLE_BUNDLE_ID=com.artifactreports.ios
APPLE_SHARED_SECRET=
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_P8_BASE64=

# -----------------------------------------------------------------------------
# Social platform OAuth (per provider)
# -----------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
# Edge-function-side redirect URI used by supabase/functions/oauth-instagram.
INSTAGRAM_OAUTH_REDIRECT_URI=https://YOUR_PROJECT.supabase.co/functions/v1/oauth-instagram/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_OAUTH_REDIRECT_URI=https://YOUR_PROJECT.supabase.co/functions/v1/oauth-tiktok/callback

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Edge-function-side aliases used by supabase/functions/oauth-youtube.
# Same values; renamed here to make the function's required env explicit.
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=https://YOUR_PROJECT.supabase.co/functions/v1/oauth-youtube/callback

X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://YOUR_PROJECT.supabase.co/functions/v1/oauth-x/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

GMB_CLIENT_ID=
GMB_CLIENT_SECRET=

UBERALL_API_KEY=

# -----------------------------------------------------------------------------
# OCR / Claude Vision
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Web report (Next.js public env)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://reports.artifact.studio
